{
  "entities": {
    "UserProfile": {
      "title": "Profil Utilisateur",
      "description": "Informations de base sur l'agriculteur.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "locations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "FieldEntry": {
      "title": "Carnet de Champ",
      "description": "Un enregistrement d'activité ou d'observation dans une parcelle.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "crop": { "type": "string", "enum": ["arachide", "mil", "maïs", "riz"] },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "photoUrl": { "type": "string" },
        "diagnostic": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "crop", "location"]
    },
    "ChatMessage": {
      "title": "Message de Chat",
      "description": "Un message individuel au sein d'une conversation.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content"]
    },
    "Conversation": {
      "title": "Session de Chat",
      "description": "Une session de discussion regroupant plusieurs messages.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Profils des utilisateurs."
    },
    "/users/{userId}/fields/{fieldId}": {
      "schema": "FieldEntry",
      "description": "Carnet de champs de l'utilisateur."
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Liste des conversations de l'utilisateur."
    },
    "/users/{userId}/conversations/{convId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Messages d'une conversation spécifique."
    }
  }
}
